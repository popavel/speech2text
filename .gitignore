# Xcode
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcworkspace/contents.xcworkspacedata
*.xcuserstate
*.xcuserdatad/
DerivedData/
build/
.DS_Store
xcuserdata/
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# SourceKit-LSP / xcode-build-server (machine-specific)
buildServer.json
.compile

# Swift Package Manager
.build/
.swiftpm/

# CocoaPods
Pods/

# Whisper models (these can be large!)
*.bin
*.mlmodelc

# Claude folder — share settings.json + the automation suite (commands, agents,
# hooks); keep personal/local bits (settings.local.json, transcripts, etc.) out.
.claude/*
!.claude/settings.json
!.claude/commands/
!.claude/agents/
!.claude/hooks/
